load kioto

pub fn assert: (cond :bool) :bool {
    return cond
}

pub fn assert_msg: (cond :bool msg :str) :bool {
    if cond { return true }
    use dasu("  FAIL: " + msg)
    return false
}

pub fn assert_eq: (a :i64 b :i64) :bool {
    if a == b { return true }
    use dasu("  FAIL: expected " + strings::from_i64(a) + ", got " + strings::from_i64(b))
    return false
}

pub fn assert_ne: (a :i64 b :i64) :bool {
    if a != b { return true }
    use dasu("  FAIL: not equal, both " + strings::from_i64(a))
    return false
}

pub fn assert_eq_str: (a :str b :str) :bool {
    if a == b { return true }
    use dasu("  FAIL: expected \"" + a + "\", got \"" + b + "\"")
    return false
}
