#!cfg::test
load kioto
load testlib

fn fib: (n :i64) :i64 {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

pub fn main: () {
    use dasu("--- stress ---")

    set start = time.unix_ms() :i64
    set result = fib(35)
    set elapsed = time.unix_ms() - start :i64
    testlib.assert_eq(9227465 result)
    use dasu("  fib(35) in " + strings.from_i64(elapsed) + "ms: ok")

    set start2 = time.unix_ms() :i64
    set result2 = fib(40)
    set elapsed2 = time.unix_ms() - start2 :i64
    testlib.assert_eq(102334155 result2)
    use dasu("  fib(40) in " + strings.from_i64(elapsed2) + "ms: ok")

    set sum = 0 :i64 mut
    set i = 0 :i64 mut
    while i < 100000 {
        set sum = sum + i
        set i = i + 1
    }
    testlib.assert_eq(4999950000 sum)
    use dasu("  sum 0..99999: ok")

    set big_str = "" :str mut
    set rep = 0 :i64 mut
    while rep < 10000 {
        set big_str = big_str + "x"
        set rep = rep + 1
    }
    testlib.assert_eq(10000 strings.len(big_str))
    use dasu("  string concat 10000x: ok")

    set lst = [] :vec[i64] mut
    set j = 0 :i64 mut
    while j < 5000 {
        set val = j :i64
        set lst = lists.push(lst val)
        set j = j + 1
    }
    testlib.assert_eq(5000 len(lst))
    testlib.assert_eq(0 lists.get(lst 0))
    testlib.assert_eq(4999 lists.get(lst 4999))
    use dasu("  5000-element list: ok")

    use dasu("all stress tests passed")
}
