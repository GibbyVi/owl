load kioto
load testlib

pub fn main: () {
    use dasu("--- math ---")

    testlib.assert_eq(5 math.abs(-5))
    testlib.assert_eq(42 math.abs(42))
    use dasu("  math.abs: ok")

    testlib.assert_eq(3 math.min(3 7))
    testlib.assert_eq(3 math.min(7 3))
    use dasu("  math.min: ok")

    testlib.assert_eq(7 math.max(3 7))
    testlib.assert_eq(7 math.max(7 3))
    use dasu("  math.max: ok")

    testlib.assert_eq(1 math.clamp(1 0 5))
    testlib.assert_eq(0 math.clamp(-1 0 5))
    testlib.assert_eq(5 math.clamp(10 0 5))
    use dasu("  math.clamp: ok")

    set r = math.range(5) :vec[i64]
    testlib.assert_eq(5 len(r))
    testlib.assert_eq(0 lists.get(r 0))
    testlib.assert_eq(4 lists.get(r 4))
    use dasu("  math.range: ok")

    set rb = math.range_between(2 6) :vec[i64]
    testlib.assert_eq(4 len(rb))
    testlib.assert_eq(2 lists.get(rb 0))
    testlib.assert_eq(5 lists.get(rb 3))
    use dasu("  math.range_between: ok")

    set rs = math.range_step(0 10 3) :vec[i64]
    testlib.assert_eq(4 len(rs))
    testlib.assert_eq(0 lists.get(rs 0))
    testlib.assert_eq(9 lists.get(rs 3))
    use dasu("  math.range_step: ok")

    set nums = [5 2 8 1 9] :vec[i64]
    testlib.assert_eq(1 math.min_list(nums))
    testlib.assert_eq(9 math.max_list(nums))
    use dasu("  math.min_list/max_list: ok")

    testlib.assert_eq(25 math.sum(nums))
    use dasu("  math.sum: ok")



    use dasu("all math tests passed")
}
