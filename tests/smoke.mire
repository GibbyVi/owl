load kioto
load ./tests/test_utils

![test] basic equality
pub fn test_basic_eq: () :bool {
    return assert_eq(1 1)
}

![test] string equality
pub fn test_str_eq: () :bool {
    return assert_eq_str("hello" "hello")
}

![test] assertion true
pub fn test_assert_true: () :bool {
    return assert(true)
}
